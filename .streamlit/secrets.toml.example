# Copy this file to .streamlit/secrets.toml for OIDC-enabled deployments.
# Never commit real client secrets or cookie secrets.

[auth]
redirect_uri = "http://localhost:8502/oauth2callback"
cookie_secret = "replace-with-at-least-32-random-bytes"

[auth.keycloak]
client_id = "vitalssight-console"
client_secret = "replace-with-keycloak-client-secret"
server_metadata_url = "https://identity.example.org/realms/vitalssight/.well-known/openid-configuration"
client_kwargs = { prompt = "select_account" }
