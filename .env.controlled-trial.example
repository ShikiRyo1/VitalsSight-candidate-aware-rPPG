# Copy values into the service environment. Do not commit real secrets.
VITALSSIGHT_AUTH_MODE=required
VITALSSIGHT_AUTH_ISSUER=https://identity.example.org/realms/vitalssight
VITALSSIGHT_AUTH_AUDIENCE=vitalssight-api
VITALSSIGHT_AUTH_CLIENT_ID=vitalssight-console
VITALSSIGHT_AUTH_JWKS_URL=https://identity.example.org/realms/vitalssight/protocol/openid-connect/certs
VITALSSIGHT_AUTH_ALGORITHMS=RS256
VITALSSIGHT_AUTH_LEEWAY_SECONDS=30
VITALSSIGHT_DEFAULT_ORGANIZATION=controlled-trial

VITALSSIGHT_DB_PATH=runtime/controlled-trial/vitalssight.db
VITALSSIGHT_UPLOAD_DIR=runtime/controlled-trial/uploads
VITALSSIGHT_MAX_UPLOAD_BYTES=209715200

VITALSSIGHT_OLLAMA_URL=http://127.0.0.1:11434
VITALSSIGHT_ASSISTANT_MODEL=qwen3.6:35b
VITALSSIGHT_ASSISTANT_VISION_MODEL=qwen3-vl:4b-instruct
VITALSSIGHT_ASSISTANT_ASR_MODEL=small
VITALSSIGHT_ASSISTANT_ACTIONS_ENABLED=false
VITALSSIGHT_ASSISTANT_THINKING=false
VITALSSIGHT_ASSISTANT_KEEP_ALIVE=0
VITALSSIGHT_VISION_KEEP_ALIVE=0
